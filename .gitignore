# DuckDB working files
closure.db
closure.db.wal
*.db
*.db.wal

# Generated exports (keep directory; ignore artifacts)
exports/*.pdf
exports/*_redacted.pdf
exports/_test_*.pdf
exports/audit.db
exports/audit_sidecar.jsonl
exports/export_map.csv
exports/decisions/

# PDF lifecycle runtime (keep dir tree via .gitkeep; ignore artifacts)
data/working/*.pdf
data/working/registry/wk_*.json
data/working/registry/_sentinel.json
data/export/*_redacted.pdf
data/source/*.pdf
data/**/_store_meta.json

# Node (none required; ignore if present)
node_modules/

# OS / editor
.DS_Store
**/.DS_Store

# Generic runtime/dev artifacts
*.log
nohup.out
tests/e2e/test-results/
tests/e2e/playwright-report/

# Agent/session scratch dropped into the tree by tooling - not project content

# Client JS in static/ is hand-authored and committed (do NOT ignore it).
# Only stray rendered HTML is ignored.
static/*.html

# Company assignment text is delivered privately, not tracked publicly
Alok_FDE_Fullstack*.txt

# Page PNGs (regenerated by scripts/setup.sh via pdftoppm)
pages/**/*.png

# Sample corpus: generate via scripts/setup.sh (keep samples/gen/** only)
samples/*.pdf
samples/identities.json
samples/manifest.json
samples/watchlist.json
samples/messy/**
!samples/messy/.gitkeep

# Stress harness: keep canonical monster.pdf + metrics; ignore multi-100MB variants and probes
samples/stress/monster_huge.pdf
samples/stress/monster_20k.pdf
samples/stress/monster_5k.pdf
samples/stress/_*.pdf
samples/stress/*.err
samples/stress/break_b1.err
samples/stress/run.err

# Public-sample pipeline proof renders (regenerate via pdf_to_png)
samples/public/_renders/

.tmp/
.playwright-mcp/
samples/public/govinfo_usreports_vol5.pdf
samples/stress/*.pdf

# Offloaded from the graded tree (archived outside the repo)
docs/ai-sessions/
Alok_FDE*
